# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/skillradar

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Reddit OAuth
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
